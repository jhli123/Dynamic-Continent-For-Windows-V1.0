            btn = tk.Button(
                tab_frame,
                text=tab,
                bg='#333333' if i == 0 else '#1a1a1a',
                fg='#FFFFFF',
                border=0,
                padx=15,
                pady=10,
                font=('Segoe UI', 10, 'bold'),
                command=lambda t=i: self.show_tab(t, tab_buttons)
            )
            btn.pack(side=tk.LEFT, padx=5)
